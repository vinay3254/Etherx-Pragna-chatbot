# ===================================================================
# ENVIRONMENT FOR docker-compose.yml (self-hosted deploy)
# ===================================================================
# Copy this file to `.env` in the repo root (same directory as
# docker-compose.yml) and fill in the actual values. This is separate
# from backend/.env, which is only used when running the backend directly
# without Docker.

# REQUIRED - Ollama Cloud API key, from ollama.com/settings/keys.
# Authenticates requests to https://ollama.com for the nemotron-3-super:cloud
# model. docker-compose will refuse to start
# without this set.
OLLAMA_API_KEY=your_ollama_cloud_api_key_here

# REQUIRED - any long random string. Signs auth tokens; docker-compose
# will refuse to start without this set.
JWT_SECRET=change-me-to-a-long-random-string

# RECOMMENDED - safety net if Ollama Cloud's free-tier quota runs out
# mid-week. Free key at console.groq.com. Leave blank to skip.
GROQ_API_KEY=

# Optional additional fallback provider.
OPENAI_API_KEY=

# Comma-separated frontend origins allowed to call the backend, e.g.
# http://your-vps-ip:5173 or https://yourdomain.com. Defaults to "*"
# (any origin) if left unset - fine to start, tighten once you have a
# real domain.
CORS_ALLOWED_ORIGINS=*

# The backend's PUBLIC URL as reachable from users' browsers - NOT
# localhost once this is running on a real VPS. Baked into the frontend
# build at build time (see chatbot-ui-vite/Dockerfile), so this must be
# correct before `docker compose build`, not just at run time.
VITE_API_URL=http://localhost:5001

# False by default - skips loading sentence-transformers/torch/faiss at
# boot (saves ~500MB-1GB+ RAM). Main chat doesn't use RAG anyway. Only set
# True if you have real RAM headroom and want the /api/rag/* endpoints.
RAG_ENABLED=False
